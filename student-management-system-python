class Student:
    def __init__(self, name, roll_no, marks):
        self.name = name
        self.roll_no = roll_no
        self.marks = marks

    def average_marks(self):
        total = 0

        for mark in self.marks.values():
            total += mark

        return total / len(self.marks)

    def highest_subject(self):
        highest_subject = ""
        highest_marks = float("-inf")

        for subject, marks in self.marks.items():
            if marks > highest_marks:
                highest_marks = marks
                highest_subject = subject

        return highest_subject, highest_marks

    def lowest_subject(self):
        lowest_subject = ""
        lowest_marks = float("inf")

        for subject, marks in self.marks.items():
            if marks < lowest_marks:
                lowest_marks = marks
                lowest_subject = subject

        return lowest_subject, lowest_marks

    def add_subject(self, subject, marks):
        self.marks[subject] = marks

    def update_marks(self, subject, marks):
        if subject in self.marks:
            self.marks[subject] = marks
        else:
            return "Subject not found"

    def grade(self):
        average = self.average_marks()

        if average >= 90:
            return "A"
        elif average >= 80:
            return "B"
        elif average >= 70:
            return "C"
        elif average >= 60:
            return "D"
        else:
            return "F"

    def passed(self):
        return self.average_marks() >= 35

    def report(self):
        return {
            "Name": self.name,
            "Roll No": self.roll_no,
            "Average": self.average_marks(),
            "Highest Subject": self.highest_subject(),
            "Lowest Subject": self.lowest_subject(),
            "Grade": self.grade(),
            "Passed": self.passed()
        }


s1 = Student(
    "Varun",
    12,
    {
        "Maths": 90,
        "Physics": 98,
        "Chemistry": 96
    }
)

print(s1.report())
